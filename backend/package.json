{
  "name": "mush2-backend",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --watch-path=src src/server.js",
    "start": "node src/server.js",
    "db:sync": "node src/sync-db.js",
    "db:seed": "node src/seed.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.js",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.js --watch",
    "test:ddd": "vitest run --config vitest.config.ts",
    "test:ddd:watch": "vitest --config vitest.config.ts"
  },
  "author": "AlejandroMaturana",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.15.1",
    "node-telegram-bot-api": "^1.1.2",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "vitest": "^3.2.4"
  }
}
