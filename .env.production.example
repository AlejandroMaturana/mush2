# ============================================================
# Mush2 — Variables de entorno para producción (Render + Supabase)
# ============================================================
# Copia este archivo como referencia.
# Los valores se configuran en Render Dashboard > Environment Variables.
# NUNCA subas credenciales reales al repositorio.

# --- Database (Supabase PostgreSQL) ---
# Lo obtienes de: Supabase > Project Settings > Database > Connection string (URI)
# Formato: postgresql://postgres:YOUR_PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# --- JWT ---
# Genera una clave segura: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-here

# --- Aplicación ---
NODE_ENV=production
PORT=3797

# --- CORS ---
# URL del frontend (la misma URL de Render si se sirve desde el backend)
CORS_ORIGIN=https://mush2.onrender.com

# --- ThingSpeak (opcional) ---
TS_API_KEY=
TS_HOST=api.thingspeak.com
TS_PORT=80

# --- MQTT (opcional — por defecto test.mosquitto.org:1883) ---
# MQTT_BROKER=mqtt://tu-broker.local:1883
# MQTT_BROKER_FALLBACK=mqtt://broker.hivemq.com:1883
