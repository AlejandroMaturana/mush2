# ── LOCAL (desarrollo) ──────────────────────────────────────────
# WIFI CREDENTIALS (firmware)
WIFI_SSID_1=YourSSID1
WIFI_PASSWORD_1=YourPassword1
WIFI_SSID_2=YourSSID2
WIFI_PASSWORD_2=YourPassword2

# THINGSPEAK (firmware only — backend reads per-device from DB)
# TS_API_KEY=YourTSAPIKey
TS_HOST=api.thingspeak.com
TS_PORT=80

DEVICE_ID=mush2_001

# LOCALHOST DB
DB_USER     =postgres
DB_HOST     =localhost
DB_NAME     =namedb
DB_PASSWORD =passworddb
DB_PORT     =5432
DATABASE_URL=postgresql://postgres:passworddb@localhost:5432/namedb

# JWT
JWT_SECRET =secretPassword123

# MQTT (Docker Compose)
MQTT_BROKER_URL=mqtt://mosquitto:1883
MQTT_BACKEND_USER=backend_bridge
MQTT_BACKEND_PASS=change_me

# ── RENDER (producción) ─────────────────────────────────────────
# En Render, estas variables se configuran en el Dashboard o vía
# render.yaml (blueprint). PostgreSQL inyecta DATABASE_URL auto.
#
# NODE_ENV=production
# PORT=3797               (asignado por Render)
# DATABASE_URL=           (viene del addon PostgreSQL)
# JWT_SECRET=             (generado por render.yaml o manual)
# CORS_ORIGIN=https://tu-app.onrender.com
# MQTT_BROKER=            (opcional)
# TELEGRAM_BOT_TOKEN=     (opcional)
# TELEGRAM_BOT_USERNAME=  (opcional)
